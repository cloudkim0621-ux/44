<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>카운터</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            margin-top: 100px;
        }
        button {
            padding: 10px 20px;
            font-size: 18px;
        }
        #count {
            font-size: 40px;
            margin: 20px;
        }
    </style>
</head>
<body>

<h1>카운터 프로그램</h1>

<div id="count">0</div>

<button onclick="increase()">+1 증가</button>

<script>
    let count = 0;

    function increase() {
        count++;
        document.getElementById("count").textContent = count;
    }
</script>

</body>
</html>
